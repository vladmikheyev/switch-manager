# Порт сервера
PORT=5000

# Режим: development или production
NODE_ENV=development

# Настройки CORS (разрешённые источники)
CORS_ORIGIN=http://localhost:3000,http://10.182.63.130:3000

# Путь к базе данных
DB_PATH=./data/switches.db

# Папка для загруженных файлов
UPLOAD_PATH=./uploads

# Максимальный размер файла (10MB)
MAX_FILE_SIZE=10485760

# Секретный ключ для сессий (поменяйте в продакшене!)
JWT_SECRET=your-super-secret-key-change-in-production

# Лимит запросов (защита от спамма)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100